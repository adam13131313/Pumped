# Copy to .env (in repo root or in this folder) and fill in.
# NEVER commit the real values.

# From your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# From your Pumped account.
# Easiest to get by opening browser devtools in your local Pumped tab and running:
#   (await window.supabase.auth.getUser()).data.user.id
#   (await window.supabase.from("memberships").select("organisation_id").limit(1).single()).data.organisation_id
PUMPED_USER_ID=your-auth-uid
PUMPED_ORGANISATION_ID=your-org-uuid
